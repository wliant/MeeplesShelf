# App
COMPOSE_PROJECT_NAME=meeplesshelf

# PostgreSQL
POSTGRES_USER=meeplesshelf
POSTGRES_PASSWORD=meeplesshelf
POSTGRES_DB=meeplesshelf
POSTGRES_PORT=5432

# Application (Docker)
APP_DATABASE_URL=postgresql+asyncpg://meeplesshelf:meeplesshelf@db:5432/meeplesshelf
APP_PORT=8000
APP_ADMIN_PASSWORD=changeme
APP_SECRET_KEY=change-this-to-a-long-random-string

# Frontend local dev (used by `cd web && npm run dev`)
VITE_API_BASE_URL=http://localhost:8000/api
